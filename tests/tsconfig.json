{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // Keep test typechecking separate from the app build. This lets the main
    // project continue excluding tests while still giving tests the same alias
    // and module-resolution behavior as src/.
    "rootDir": "..",
    "types": ["vite/client", "node", "@cloudflare/vitest-pool-workers/types"],
    "paths": {
      "@/*": ["../src/*"],
      "@tests/*": ["./*"]
    }
  },
  "include": ["./**/*", "../worker-configuration.d.ts", "../src/types/**/*.d.ts"],
  "exclude": ["../node_modules", "../dist"]
}
