{
  "name": "bland",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "types:generate": "wrangler types --env-file .dev.vars.example",
    "test": "vitest run --passWithNoTests",
    "deploy": "npm run db:migrate && npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply bland-prod --local",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed-initial-user": "node --import tsx scripts/seed-initial-user.ts --local"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@noble/hashes": "^2.0.1",
    "@tanstack/react-router": "^1.168.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "lucide-react": "^1.7.0",
    "partyserver": "^0.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2",
    "ulidx": "^2.4.0",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.1.4",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.10.0"
  }
}
