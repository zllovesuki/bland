{
  "name": "bland",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit && npm run typecheck:tests",
    "typecheck:tests": "tsc -p tests/tsconfig.json --noEmit",
    "types:generate": "wrangler types --env-file .dev.vars.example",
    "test": "vitest run --passWithNoTests",
    "deploy": "npm run db:migrate && npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply bland-prod --local",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed-initial-user": "node --import tsx scripts/seed-initial-user.ts --local"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react": "^0.27.19",
    "@noble/hashes": "^2.0.1",
    "@tanstack/react-router": "^1.168.0",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-collaboration": "^3.22.2",
    "@tiptap/extension-collaboration-caret": "^3.22.2",
    "@tiptap/extension-drag-handle": "^3.22.2",
    "@tiptap/extension-drag-handle-react": "^3.22.2",
    "@tiptap/extension-file-handler": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-node-range": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-task-item": "^3.22.2",
    "@tiptap/extension-task-list": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/suggestion": "^3.22.2",
    "@tiptap/y-tiptap": "^3.0.2",
    "drizzle-orm": "^0.45.2",
    "emoji-picker-react": "^4.18.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "partyserver": "^0.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ulidx": "^2.4.0",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.1.4",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.4.0",
    "prosemirror-schema-basic": "^1.2.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.10.0"
  }
}
