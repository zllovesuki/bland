{
  "name": "bland",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "emoji:generate": "node --import tsx scripts/generate-emoji-data.ts",
    "dev": "vite dev",
    "build": "vite build && vite build -c vite.sites.config.ts",
    "lint": "eslint src tests scripts vite.config.ts eslint.config.js",
    "typecheck": "tsc --noEmit && npm run typecheck:tests",
    "typecheck:tests": "tsc -p tests/tsconfig.json --noEmit",
    "types:generate": "wrangler types --env-file .dev.vars.example",
    "test": "vitest run --passWithNoTests",
    "test:client": "vitest run --project client --project client-dom",
    "test:client-dom": "vitest run --project client-dom",
    "test:sites": "vitest run --project sites --project sites-dom",
    "test:shared": "vitest run --project shared",
    "test:worker": "vitest run --project worker-unit --project worker-runtime",
    "test:worker-unit": "vitest run --project worker-unit",
    "test:worker-runtime": "vitest run --project worker-runtime",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "deploy": "npm run db:migrate:remote && npm run build && wrangler deploy",
    "db:generate:d1": "drizzle-kit generate --config=drizzle-d1.config.ts",
    "db:generate:docsync-do": "drizzle-kit generate --config=drizzle-docsync-do.config.ts",
    "db:generate:workspace-indexer": "drizzle-kit generate --config=drizzle-workspace-indexer.config.ts",
    "db:generate:durable": "npm run db:generate:docsync-do && npm run db:generate:workspace-indexer",
    "db:generate": "npm run db:generate:d1 && npm run db:generate:durable",
    "db:migrate:local": "wrangler d1 migrations apply bland-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply bland-prod --remote",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed-initial-user": "node --import tsx scripts/seed-initial-user.ts",
    "db:seed-initial-user:local": "node --import tsx scripts/seed-initial-user.ts --local",
    "db:seed-initial-user:remote": "node --import tsx scripts/seed-initial-user.ts --remote",
    "predev": "npm run emoji:generate",
    "prebuild": "npm run emoji:generate",
    "pretypecheck": "npm run emoji:generate",
    "pretest": "npm run emoji:generate"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react": "^0.27.19",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@noble/hashes": "^2.0.1",
    "@sentry/react": "^10.53.1",
    "@serwist/window": "^9.5.11",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.3",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-character-count": "^3.23.4",
    "@tiptap/extension-code-block": "^3.23.4",
    "@tiptap/extension-collaboration": "^3.23.4",
    "@tiptap/extension-collaboration-caret": "^3.23.4",
    "@tiptap/extension-details": "^3.23.4",
    "@tiptap/extension-drag-handle": "^3.23.4",
    "@tiptap/extension-drag-handle-react": "^3.23.4",
    "@tiptap/extension-emoji": "^3.23.4",
    "@tiptap/extension-file-handler": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-node-range": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text-align": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-typography": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/static-renderer": "3.23.4",
    "@tiptap/suggestion": "^3.23.4",
    "@tiptap/y-tiptap": "^3.0.3",
    "dexie": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.19",
    "jose": "^6.0.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "partyserver": "^0.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ulid": "^3.0.2",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.2.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@cloudflare/vite-plugin": "^1.37.1",
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@serwist/vite": "^9.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.0",
    "prosemirror-schema-basic": "^1.2.4",
    "serwist": "^9.5.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "lodash-es": "4.18.1",
    "@radix-ui/react-tabs": "1.1.13"
  }
}
